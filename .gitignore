# Runtime data (lives in CLAUDE_PLUGIN_DATA for distributed installs)
data/memory.db
data/inject_cache/
data/path_cache.json
data/backfill_complete
logs/

# User-local settings (personal path mappings)
config/settings.toml

# Generated by setup.mjs (copy of scripts/pyproject.toml)
pyproject.toml
uv.lock

# Python
.venv/
scripts/.venv/
scripts/__pycache__/
__pycache__/
*.pyc

# Keep directory structure
!data/.gitkeep
!logs/.gitkeep

# ONNX models (too large for git, downloaded/copied by setup.mjs)
models/

# Node
node_modules/
