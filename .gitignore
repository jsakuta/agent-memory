data/memory.db
data/inject_cache/
data/path_cache.json
logs/

# Python
scripts/.venv/
scripts/__pycache__/
__pycache__/
*.pyc

# Keep directory structure
!data/.gitkeep
!logs/.gitkeep

# ONNX models (too large for git, copied by setup.mjs)
models/*/model*.onnx
models/*/tokenizer.json

# Node
node_modules/
