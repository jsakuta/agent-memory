{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"'${CLAUDE_PLUGIN_ROOT}/scripts/.venv/Scripts/python' '${CLAUDE_PLUGIN_ROOT}/scripts/inject.py'\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"'${CLAUDE_PLUGIN_ROOT}/scripts/.venv/Scripts/python' '${CLAUDE_PLUGIN_ROOT}/scripts/capture.py'\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
